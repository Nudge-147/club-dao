# Note: the current code still hardcodes cloud baseUrl in `src/App.tsx`.
# These placeholders are prepared for future refactor and deployment configs.

VITE_CLOUD_BASE_URL=https://your-laf-app.example.com
VITE_APP_NAME=ClubDAO
